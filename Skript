let companies = []; // loaded dataset

// Try to fetch companies.json; fallback to embedded sample if fetch fails.
async function loadCompanies() {
  try {
    const resp = await fetch('companies.json');
    if (!resp.ok) throw new Error('companies.json not found');
    companies = await resp.json();
  } catch (e) {
    console.warn('Could not fetch companies.json, using inline sample. Error:', e);
    companies = sampleCompanies(); // fallback
  }
  populatePopular();
  updateSuggestions();
}

